    "dev:clean": "rm -rf .next && npm run dev",
    "gnx:analyze": "bash scripts/gnx-analyze.sh",
    "gnx:analyze:embeddings": "bash scripts/gnx-analyze.sh --embeddings",
    "gnx:detect-changes": "tsx scripts/gnx-detect-changes.ts",
    "build": "npm run perf:flags:check && npm run openclaw:prebuilt:verify-meta && next build",
    "build:scheduler": "node build-scheduler.js",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:openclaw": "vitest run src/lib/__tests__/openclaw-bindings.test.ts src/lib/__tests__/openclaw-intent-parser.test.ts src/lib/__tests__/openclaw-proxy-normalize.test.ts src/lib/__tests__/openclaw-runs-service.test.ts src/lib/__tests__/openclaw-canonical-routes.test.ts src/lib/__tests__/openclaw-command-payload-policy-coverage.test.ts src/lib/__tests__/openclaw-command-risk-policy-coverage.test.ts src/lib/__tests__/openclaw-risk-policy.test.ts src/lib/__tests__/openclaw-command-service-confirm.test.ts src/lib/openclaw/commands/payload-policy.behavior.test.ts src/lib/openclaw/auth.test.ts src/lib/openclaw/ai-models.test.ts src/lib/openclaw/config.sync-user-scope.test.ts src/lib/openclaw/feishu-accounts.test.ts src/lib/openclaw/feishu-chat-health.test.ts src/lib/openclaw/gateway.test.ts src/lib/openclaw/reports.test.ts src/lib/openclaw/settings.test.ts src/app/api/openclaw/feishu/chat-health/ingest/route.test.ts src/lib/openclaw/autoads-client.test.ts",
    "test:openclaw:guard": "vitest run src/lib/__tests__/openclaw-intent-parser.test.ts src/lib/__tests__/openclaw-proxy-normalize.test.ts src/lib/__tests__/openclaw-canonical-routes.test.ts src/lib/__tests__/openclaw-command-payload-policy-coverage.test.ts src/lib/__tests__/openclaw-command-risk-policy-coverage.test.ts src/lib/__tests__/openclaw-risk-policy.test.ts src/lib/__tests__/openclaw-command-service-confirm.test.ts src/lib/openclaw/commands/payload-policy.behavior.test.ts src/lib/openclaw/autoads-client.test.ts",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:queue-redis": "tsx scripts/test-queue-redis.ts",
    "openclaw:binding:smoke": "tsx scripts/openclaw-binding-smoke.ts",
    "openclaw:redact-action-logs": "tsx scripts/openclaw-redact-action-logs.ts",
    "openclaw:prebuilt:build": "bash scripts/build-openclaw-prebuilt.sh",
    "openclaw:prebuilt:verify-meta": "node scripts/verify-openclaw-prebuilt-meta.js",
    "openclaw:prebuilt:verify": "bash scripts/verify-openclaw-prebuilt.sh",
    "openclaw:prebuilt:refresh": "npm run openclaw:prebuilt:build && npm run openclaw:prebuilt:verify",
    "click-farm:audit-no-campaign": "tsx scripts/click-farm-audit-no-campaign.ts",
    "db:init": "mkdir -p data && tsx scripts/db-init-smart.ts",
    "db:reset": "rm -f data/autoads.db && npm run db:init",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:schema": "tsx scripts/generate-schema.ts",
    "db:backup": "tsx scripts/backup-database.ts",
    "db:backfill-jsonb": "tsx scripts/backfill-jsonb-double-encoded.ts",
    "campaigns:backfill-names": "tsx scripts/backfill-campaign-names-from-google.ts",
    "db:verify-settings": "tsx scripts/verify-database-settings.ts",
    "db:clean-settings": "tsx scripts/clean-database-settings.ts",
    "admin:ensure": "tsx scripts/ensure-admin-account.ts",
    "validate-schema": "tsx scripts/validate-db-schema.ts",
    "validate:search-term": "tsx scripts/validate-search-term-activation.ts",
    "type-check": "tsc --noEmit",
    "verify:google-ads": "tsx scripts/verify-google-ads-config.ts",
    "test:competitor-compression": "tsx scripts/run-competitor-ab-test.ts",
    "perf:flags:check": "tsx scripts/performance-release-governance.ts check",
    "perf:rollback:template": "tsx scripts/performance-release-governance.ts rollback-template",
    "perf:rollback:all:template": "tsx scripts/performance-release-governance.ts rollback-template --all",
    "perf:rollback:drill": "tsx scripts/performance-release-governance.ts drill"
  },
