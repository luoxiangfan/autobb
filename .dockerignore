# OpenClaw 源码不参与镜像构建（使用预编译产物）
openclaw/*
!openclaw/package.json
!openclaw/.source-commit
# 注意：以下配置文件是构建必需的，不能排除
# tailwind.config.ts  - Tailwind CSS配置
# postcss.config.js   - PostCSS配置
# tsconfig.json       - TypeScript配置（包含@/路径别名）
# build-scheduler.js  - 调度器打包脚本（构建时需要）
# nginx.conf          - Nginx配置（单容器部署必需）
# supervisord.conf    - Supervisord配置（单容器部署必需）

.openclaw-prebuilt-tmp/
