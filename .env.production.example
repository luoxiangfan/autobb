# ============================================
# AutoAds 生产环境变量配置（最小化）
# ============================================
# 使用说明:
# 1. 复制此文件为 .env.production
# 2. 填写实际的配置值
# 3. 确保 .env.production 已添加到 .gitignore（不要提交到版本控制）
#
# 注意: Google Ads、AI API、代理等业务配置无需在此设置
#       用户登录后在 /settings 页面配置即可（存储在数据库中）
# ============================================

# ============================================
# 数据库配置（必需，二选一）
# ============================================

# 方式1: PostgreSQL（生产环境推荐）
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://autoads:your_strong_password@postgres-host:5432/autoads

# 方式2: SQLite（轻量级部署）
# 如使用SQLite，注释掉上面的DATABASE_URL，取消下面的注释
# DATABASE_PATH=/app/data/autoads.db

# ============================================
# Redis配置（强烈推荐）
# ============================================
# 用于: 网页抓取缓存、关键词缓存、AI创意缓存
# 如不配置，相关缓存功能将禁用

REDIS_URL=redis://redis-host:6379
# REDIS_PASSWORD=your_redis_password
# Redis 不可用时是否仍允许 click-farm 回退到内存队列（生产建议 true，避免 OOM）
CLICK_FARM_REQUIRE_REDIS_IN_PRODUCTION=true

# 8C16G 生产配置推荐（单容器 + supervisord）
NODE_MAX_OLD_SPACE_SIZE_WEB=5120
NODE_MAX_OLD_SPACE_SIZE_SCHEDULER=2048
NODE_MAX_OLD_SPACE_SIZE_BACKGROUND_WORKER=4096
NODE_MAX_OLD_SPACE_SIZE_OPENCLAW=1536
QUEUE_GLOBAL_CONCURRENCY=64
QUEUE_PER_USER_CONCURRENCY=16
QUEUE_CLICK_FARM_CONCURRENCY=40
QUEUE_CLICK_FARM_CONCURRENCY_HARD_CAP=40
QUEUE_URL_SWAP_CONCURRENCY=8
CLICK_FARM_MAX_INFLIGHT=40
CLICK_FARM_MAX_INFLIGHT_HARD_CAP=40

# 🔧 补点击任务内存压力配置（修复15.5%点击缺失问题）
# 执行器内存压力阈值（默认80%，建议90%）
CLICK_FARM_EXECUTOR_HEAP_PRESSURE_PCT=90
# 批次分发器内存压力阈值（默认82%，建议90%）
CLICK_FARM_BATCH_HEAP_PRESSURE_PCT=90
# 批次大小（默认20，高点击量任务建议10）
CLICK_FARM_BATCH_SIZE=10
# 批次间隔毫秒（默认200ms，建议500ms）
CLICK_FARM_BATCH_DELAY_MS=500

CLICK_FARM_HEAP_PRESSURE_PCT=88
CLICK_FARM_TRIGGER_MODE=async
CLICK_FARM_BATCH_SIZE_MAX=100
CLICK_FARM_BATCH_DELAY_MS=200
CLICK_FARM_BATCH_HEAP_PRESSURE_PCT=82
QUEUE_CLICK_FARM_HEAP_PRESSURE_PCT=72
CLICK_FARM_TRIGGER_HEAP_PRESSURE_PCT=75
CLICK_FARM_EXECUTOR_HEAP_PRESSURE_PCT=80
QUEUE_DATA_SYNC_RUN_ON_START=true
QUEUE_DATA_SYNC_STARTUP_DELAY_MS=30000
QUEUE_URL_SWAP_RUN_ON_START=true
QUEUE_URL_SWAP_STARTUP_DELAY_MS=10000

# ============================================
# 安全密钥（必需）
# ============================================

# JWT认证密钥（至少32字符）
# 生成命令: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_min_32_characters_long_here

# 数据加密密钥（64字符十六进制，用于AES-256-GCM加密敏感配置）
# 生成命令: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here_change_me

# ============================================
# 应用配置
# ============================================

# 应用访问URL（影响OAuth回调地址）
NEXT_PUBLIC_APP_URL=https://autoads.dev
# OpenClaw -> AutoAds 内部调用地址（避免走公网）
# INTERNAL_APP_URL=http://127.0.0.1:3000

# Node.js环境
NODE_ENV=production

# 时区设置（影响定时任务执行时间）
TZ=Asia/Shanghai

# OpenClaw 网关与飞书卡片回调（可选）
# 默认内部网关地址为 http://127.0.0.1:18789，如为同机部署通常无需覆盖
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_CARD_CONFIRM_URL=https://autoads.dev/api/openclaw/commands/confirm
# OPENCLAW_CARD_CONFIRM_TOKEN=replace_with_gateway_token
# OPENCLAW_CARD_CONFIRM_TIMEOUT_MS=10000
# OpenClaw 网关认证令牌（用于 API 调用鉴权）
# OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token_here
# OpenClaw 网关端口（默认 18789）
# OPENCLAW_GATEWAY_PORT=18789
# OpenClaw 日志级别（debug | info | warn | error，默认 info）
# OPENCLAW_LOG_LEVEL=info

# ============================================
# 可选配置
# ============================================

# Next.js禁用遥测
NEXT_TELEMETRY_DISABLED=1

# 日志级别: debug | info | warn | error
# LOG_LEVEL=info

# ============================================
# Docker Compose 数据库配置
# （仅当使用docker-compose自带PostgreSQL时需要）
# ============================================

# POSTGRES_DB=autoads
# POSTGRES_USER=autoads
# POSTGRES_PASSWORD=your_strong_password

# ============================================
# 以下配置无需在环境变量中设置
# 用户登录后在 /settings 页面配置
# ============================================
#
# Google Ads API:
#   - Client ID / Client Secret / Developer Token
#   - 通过OAuth授权获取Refresh Token
#   - 支持每个用户独立配置
#
# AI引擎:
#   - Gemini API Key（直连模式）
#   - Vertex AI配置（GCP项目ID、区域、Service Account JSON）
#   - 支持每个用户独立配置
#
# 代理配置:
#   - 多国家代理URL（JSON格式）
#   - 支持每个用户独立配置
#
# 所有业务配置存储在数据库中，敏感字段使用AES-256-GCM加密
# ============================================
