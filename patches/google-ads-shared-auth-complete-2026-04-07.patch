+  description TEXT,                       -- 配置描述
+  client_id TEXT NOT NULL,                -- OAuth Client ID
+  client_secret TEXT NOT NULL,            -- OAuth Client Secret（加密存储）
+  developer_token TEXT NOT NULL,          -- Developer Token（加密存储）
