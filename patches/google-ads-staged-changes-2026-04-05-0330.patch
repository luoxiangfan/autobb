+-      `强制发布失败：${assetLabel === 'Headlines' ? `至少保留${minimumCount}个标题` : `至少保留${minimumCount}个描述`}，当前仅${normalized.length}个。`
+-    )
+-  }
+-
+-  if (normalized.length >= requiredCount) {
+-    return normalized.slice(0, requiredCount)
+-  }
+-
