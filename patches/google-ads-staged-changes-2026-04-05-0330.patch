+++
+++CREATE TABLE IF NOT EXISTS google_ads_user_oauth_bindings (
+++  id TEXT PRIMARY KEY,
+++  user_id INTEGER NOT NULL,               -- 用户 ID
+++  oauth_config_id TEXT NOT NULL,          -- 关联的共享 OAuth 配置 ID
+++  refresh_token TEXT,                     -- OAuth Refresh Token（加密存储）
