+-
+-    "$@" &
+-    CURRENT_CHILD_PID=$!
+-    wait "${CURRENT_CHILD_PID}"
+-    EXIT_CODE=$?
+-    CURRENT_CHILD_PID=""
+-    return "${EXIT_CODE}"
+-}
+-
