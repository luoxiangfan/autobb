+++-- 管理员将服务账号绑定到用户
+++
+++CREATE TABLE IF NOT EXISTS google_ads_user_sa_bindings (
+++  id TEXT PRIMARY KEY,
+++  user_id INTEGER NOT NULL,               -- 用户 ID
