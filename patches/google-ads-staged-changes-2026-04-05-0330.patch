+-    TERMINATION_REQUESTED=1
+-    if [ -n "${CURRENT_CHILD_PID:-}" ]; then
+-        kill -TERM "${CURRENT_CHILD_PID}" 2>/dev/null || true
+-        wait "${CURRENT_CHILD_PID}" 2>/dev/null || true
+-        CURRENT_CHILD_PID=""
+-    fi
