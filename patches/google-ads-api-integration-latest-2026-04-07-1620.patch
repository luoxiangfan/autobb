+  req: NextRequest, 
+  { params }: { params: { id: string } }
+) {
+  const admin = await getAdminUser(req)
+  if (!admin) {
+    return NextResponse.json({ error: 'Unauthorized - Admin access required' }, { status: 401 })
+  }
+
+  try {
+    const serviceAccountId = params.id
