+      SET is_active = 0, updated_at = ${db.type === 'postgres' ? 'NOW()' : "datetime('now')"}
+      WHERE service_account_id = ? AND user_id = ?
+    `, [serviceAccountId, userId])
+
+    return NextResponse.json({ 
+      success: true,
+      data: { service_account_id: serviceAccountId, user_id: userId }
