# ==========================================
# AutoAds 生产环境最简配置模板
# ==========================================
# 说明：
# ✅ 必需 - 应用无法启动或核心功能无法运行
# 🔶 推荐 - 影响核心功能体验
# ⚪ 可选 - 优化和增强功能

# ==========================================
# ✅ 应用基础配置（必需）
# ==========================================
NEXT_PUBLIC_APP_URL=https://your-domain.com
# OpenClaw -> AutoAds 内部调用地址（同容器部署请固定为回环地址）
INTERNAL_APP_URL=http://127.0.0.1:3000
NODE_ENV=production

# OpenClaw 网关与飞书卡片回调（可选）
# 默认内部网关地址为 http://127.0.0.1:18789，如为同机部署通常无需覆盖
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_CARD_CONFIRM_URL=https://your-domain.com/api/openclaw/commands/confirm
# OPENCLAW_CARD_CONFIRM_TOKEN=replace_with_gateway_token
# OPENCLAW_CARD_CONFIRM_TIMEOUT_MS=10000

# ==========================================
# ✅ JWT 认证配置（必需）
# ==========================================
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=请替换为64位随机十六进制字符串
JWT_EXPIRES_IN=7d

# ==========================================
# ✅ PostgreSQL 数据库配置（必需）
# ==========================================
# 格式: postgresql://用户名:密码@主机:端口/数据库名?参数
# 示例: postgresql://postgres:password@localhost:5432/autoads?directConnection=true
DATABASE_URL=postgresql://postgres:your_password@your_host:5432/autoads?directConnection=true

# ==========================================
# ✅ 数据加密密钥（必需 - 必须与开发环境一致）
# ==========================================
# ⚠️ 重要：此密钥必须与开发环境完全一致，否则无法解密迁移的配置数据
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=请使用开发环境相同的32字节十六进制密钥
ENCRYPTION_IV_LENGTH=16

# ==========================================
# ✅ Google OAuth 认证配置（必需）
# ==========================================
# 获取方法: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# ==========================================
# 🔶 Redis 缓存配置（推荐）
# ==========================================
# 用于缓存热点数据、会话管理、速率限制
# 格式: redis://用户名:密码@主机:端口
REDIS_URL=redis://default:your_redis_password@your_redis_host:6379
# Redis 不可用时是否仍允许 click-farm 回退到内存队列（生产建议 true，避免 OOM）
CLICK_FARM_REQUIRE_REDIS_IN_PRODUCTION=true

# 8C16G 生产配置推荐（单容器 + supervisord）
NODE_MAX_OLD_SPACE_SIZE_WEB=5120
NODE_MAX_OLD_SPACE_SIZE_SCHEDULER=2048
NODE_MAX_OLD_SPACE_SIZE_BACKGROUND_WORKER=4096
NODE_MAX_OLD_SPACE_SIZE_OPENCLAW=1536
QUEUE_GLOBAL_CONCURRENCY=64
QUEUE_PER_USER_CONCURRENCY=16
QUEUE_CLICK_FARM_CONCURRENCY=40
QUEUE_CLICK_FARM_CONCURRENCY_HARD_CAP=40
QUEUE_URL_SWAP_CONCURRENCY=8
CLICK_FARM_MAX_INFLIGHT=40
CLICK_FARM_MAX_INFLIGHT_HARD_CAP=40
CLICK_FARM_HEAP_PRESSURE_PCT=88
CLICK_FARM_TRIGGER_MODE=async
CLICK_FARM_BATCH_SIZE=20
CLICK_FARM_BATCH_SIZE_MAX=100
CLICK_FARM_BATCH_DELAY_MS=200
CLICK_FARM_BATCH_HEAP_PRESSURE_PCT=82
QUEUE_CLICK_FARM_HEAP_PRESSURE_PCT=72
CLICK_FARM_TRIGGER_HEAP_PRESSURE_PCT=75
CLICK_FARM_EXECUTOR_HEAP_PRESSURE_PCT=80

# ==========================================
# 🔶 AI API 配置（推荐 - 核心功能需要）
# ==========================================
# 注意：管理员配置导入后，数据库中的 AI 配置优先级更高
# 如果数据库中未配置 Vertex AI，则使用此 Gemini API Key

# Gemini API Key (备用 AI 引擎)
# 获取方法: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# 输出异常大时是否记录完整 AI 响应（默认 false）
# GEMINI_LOG_FULL_RESPONSE=false

# ==========================================
# 🔶 Google Ads API 配置（推荐 - 核心功能需要）
# ==========================================
# 注意：管理员配置导入后，数据库中的 Google Ads 配置优先级更高
# 这些环境变量仅作为备用配置

# OAuth 2.0 配置（通常与 Google OAuth 相同）
GOOGLE_ADS_CLIENT_ID=your_google_ads_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-your_google_ads_client_secret

# Developer Token（从 Google Ads MCC 账户获取）
# 申请地址: https://ads.google.com/aw/apicenter
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token

# MCC Manager 账户 ID（不含连字符）
# 示例: 如果账户是 123-456-7890，则填写 1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_manager_account_id

# ==========================================
# ⚪ 代理配置（可选 - 某些地区访问 Google API 需要）
# ==========================================
PROXY_ENABLED=false
PROXY_URL=

# ==========================================
# ⚪ 安全配置（可选 - 使用默认值）
# ==========================================
BCRYPT_SALT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ==========================================
# ⚪ 数据同步配置（可选 - 使用默认值）
# ==========================================
SYNC_INTERVAL_HOURS=6
ENABLE_AUTO_SYNC=true
# 队列内置调度器：启动时是否立即执行首轮数据同步检查（默认true）
# 建议生产保留 true，但通过延迟减少冷启动竞争
QUEUE_DATA_SYNC_RUN_ON_START=true
# 首轮数据同步检查延迟（毫秒，默认30000）
QUEUE_DATA_SYNC_STARTUP_DELAY_MS=30000

# URL Swap 调度器启动行为（默认启动后10秒执行首轮检查）
QUEUE_URL_SWAP_RUN_ON_START=true
QUEUE_URL_SWAP_STARTUP_DELAY_MS=10000

# ==========================================
# ⚪ 链接检查配置（可选 - 使用默认值）
# ==========================================
LINK_CHECK_ENABLED=true
LINK_CHECK_CRON=0 2 * * *
LINK_CHECK_TIMEOUT_MS=10000

# ==========================================
# ⚪ 备份配置（可选 - 使用默认值）
# ==========================================
BACKUP_CRON_SCHEDULE=0 3 * * *
ENABLE_AUTO_BACKUP=true
BACKUP_DIR=./data/backups
MAX_BACKUP_DAYS=30

# ==========================================
# ⚪ 速率限制配置（可选 - 使用默认值）
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# ⚪ 日志配置（可选 - 使用默认值）
# ==========================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# ==========================================
# ⚪ Google Ads API 高级配置（可选 - 使用默认值）
# ==========================================
GOOGLE_ADS_API_VERSION=v16
GOOGLE_ADS_REQUEST_TIMEOUT_MS=60000
GOOGLE_ADS_BATCH_SIZE=1000
GOOGLE_ADS_REPORT_PAGE_SIZE=10000
GOOGLE_ADS_LOG_LEVEL=info
# Google Ads 文案政策防护模式: strict | balanced | preserve-volume
# 默认 balanced（敏感词优先改写，仅极高风险硬拦截）
GOOGLE_ADS_POLICY_GUARD_MODE=balanced
